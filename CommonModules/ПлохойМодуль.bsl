// Процедура демонстрирует корректное суммирование
//
Процедура ХорошаяПроцедура1() Экспорт
	
	СуммаА = 0;
	СуммаБ = 0;
	СуммаВ = 0;
	СуммаГ = 0;
	СуммаД = 0;
	
	Для Счетчик = 1 По 100 Цикл
		СуммаА = СуммаА + 1;
		СуммаБ = СуммаБ + 1;
		СуммаВ = СуммаВ + 1;
		СуммаГ = СуммаГ + 1;
		СуммаД = СуммаД + 1;
	КонецЦикла;
	
	ОбщаяСумма = СуммаА + СуммаБ + СуммаВ + СуммаГ + СуммаД;
	Сообщить("Общая сумма: " + ОбщаяСумма);
	
КонецПроцедуры


